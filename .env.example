# ==============================================================================
# Global Configuration Environment Variables
# ==============================================================================

# Backend Configuration
PORT=3000
BACKEND_URL=http://localhost:3000

# Frontend Configuration
VITE_BACKEND_URL=http://localhost:3000

# Google Gemini API (LLM & Embeddings)
# Get a free API Key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Support (Optional alternative)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Deepgram API (Speech-to-Text & Text-to-Speech)
# Get a free API Key with $200 credits from: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# LiveKit WebRTC Configuration
# For local server development:
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# For LiveKit Cloud Sandbox (recommended):
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your_cloud_api_key_here
# LIVEKIT_API_SECRET=your_cloud_api_secret_here
